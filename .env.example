# Grafana 로그 조회 설정 템플릿.
# 이 파일을 .env로 복사한 뒤 값을 채운다:  cp .env.example .env
# .env는 .gitignore로 커밋이 막혀 있다. 자세한 설명은 docs/grafana-setup.md 참조.

# ── 필수: Keycloak SSO 계정 (브라우저 자동 로그인용) ──
# Grafana는 Keycloak으로만 로그인하므로, 이 값은 Grafana 계정이 아니라 Keycloak 계정이다.
KEYCLOAK_USERNAME=
KEYCLOAK_PASSWORD=

# ── 선택: 기본값으로 충분하면 비워둔다 ──
# 전용 Chrome CDP 포트 (오더비 9222와 분리하려고 기본 9223)
# GRAFANA_CDP_PORT=9223
# Chrome 실행 파일 경로 (표준 위치에서 못 찾을 때만)
#   macOS 예:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Windows 예: C:\Program Files\Google\Chrome\Application\chrome.exe
# GRAFANA_CHROME_PATH=
# Authenticator 확장 ID (다른 OTP 확장을 쓸 때만)
# GRAFANA_OTP_EXTENSION_ID=bhghoamapcdpbohphigoooaddinpkbai
# 확장 팝업에서 찾을 계정 라벨
# GRAFANA_OTP_ACCOUNT=kakaostyle
# 세션·전용 프로필 저장 위치 (기본 ~/.logisbi)
# LOGISBI_STATE_DIR=
# Grafana 주소 오버라이드 (사내 주소가 바뀔 때만)
# GRAFANA_URL=https://grafana.zigzag.in
# GRAFANA_ALPHA_URL=https://grafana.alpha.zigzag.in
