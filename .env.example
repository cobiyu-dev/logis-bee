# Grafana 로그 조회 설정 템플릿.
# 이 파일을 .env로 복사한 뒤 값을 채운다:  cp .env.example .env
# .env는 .gitignore로 커밋이 막혀 있다. 자세한 설명은 docs/grafana-setup.md 참조.

# ── 필수: Keycloak SSO 계정 (브라우저 자동 로그인용) ──
# Grafana는 Keycloak으로만 로그인하므로, 이 값은 Grafana 계정이 아니라 Keycloak 계정이다.
KEYCLOAK_USERNAME=
KEYCLOAK_PASSWORD=

# ── 선택: 기본값으로 충분하면 비워둔다 ──
# 전용 Chrome CDP 포트 (오더비 9222와 분리하려고 기본 9223)
# GRAFANA_CDP_PORT=9223
# Chrome 실행 파일 경로 (표준 위치에서 못 찾을 때만)
#   macOS 예:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Windows 예: C:\Program Files\Google\Chrome\Application\chrome.exe
# GRAFANA_CHROME_PATH=
# Authenticator 확장 ID (다른 OTP 확장을 쓸 때만)
# GRAFANA_OTP_EXTENSION_ID=bhghoamapcdpbohphigoooaddinpkbai
# 확장 팝업에서 찾을 계정 라벨
# GRAFANA_OTP_ACCOUNT=kakaostyle
# 세션·전용 프로필 저장 위치 (기본 ~/.logisbi)
# LOGISBI_STATE_DIR=
# Grafana 주소 오버라이드 (사내 주소가 바뀔 때만)
# GRAFANA_URL=https://grafana.zigzag.in
# GRAFANA_ALPHA_URL=https://grafana.alpha.zigzag.in

# ── WMS 모닝 에러 브리핑 (스케줄러) ──
# 아래 셋이 있으면 봇 기동 시 매일 아침 브리핑 스케줄러가 켜진다.
# BRIEFING_CHANNEL이 없으면 스케줄러는 비활성(봇 자체는 정상 동작).
# 게시할 Slack 채널 ID (봇이 초대돼 있어야 함)
# BRIEFING_CHANNEL=
# 브리핑을 저장·비교할 Notion 부모 DB(block) id. 없으면 Notion 단계 생략.
# BRIEFING_NOTION_DB=
# 실행 스케줄(cron, Asia/Seoul). 비우면 평일 09:10 KST("10 9 * * 1-5").
# BRIEFING_CRON=10 9 * * 1-5

# ── 프로젝트 소스 참조 (질문에 답할 때 코드 읽기) ──
# 읽을 프로젝트는 code-projects.json에 등록한다(개인 경로라 gitignore, example 참고).
# CODE_SYNC=1이면 멘션 처리 전에 각 프로젝트를 remote main으로 강제 최신화한다
#   (git checkout main + reset --hard origin/main). 로컬 변경이 있으면 날아가므로,
#   아무도 수정하지 않는 봇 구동 환경에서만 켠다. 개발자 로컬에서는 켜지 마라(기본 꺼짐).
# CODE_SYNC=1
# 최신화 대상 브랜치. 비우면 main.
# CODE_SYNC_BRANCH=main
# 프로젝트 목록 파일 경로 오버라이드(기본: 프로젝트 루트의 code-projects.json).
# CODE_PROJECTS_FILE=
