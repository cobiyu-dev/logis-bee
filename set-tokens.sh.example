# 사용법: 이 파일을 set-tokens.sh로 복사하고 실제 값을 채운 뒤,
#   source set-tokens.sh
# 로 현재 셸에 주입한다. 그 셸에서 npm run dev(개발) 또는 npm start(운영)를 실행한다.
#
# set-tokens.sh는 .gitignore로 커밋이 차단된다. 그래도 평문 파일이므로 취급 주의.
#
# ─────────────────────────────────────────────────────────────
# 중요: 운영과 개발은 서로 다른 Slack 앱을 써야 한다.
#
# 같은 앱 토큰으로 두 곳(운영 PC + 개발 PC)에서 봇을 동시에 띄우면, Slack이 멘션
# 이벤트를 두 프로세스에 번갈아 보낸다. 그러면 개발 중인(반쯤 고친) 코드가 실제
# 사용자 답변을 가로채고, 모닝 브리핑도 두 번 게시된다. 이를 막으려면 개발용 Slack
# 앱(예: "로대리-dev")을 따로 만들어 토큰을 분리하고, 각 앱을 자기 채널에만 초대한다.
# ─────────────────────────────────────────────────────────────

# ── 공통: Slack 토큰 (운영 PC는 운영 앱 토큰, 개발 PC는 개발 앱 토큰을 넣는다) ──
export SLACK_BOT_TOKEN='xoxb-...'   # Bot User OAuth Token
export SLACK_APP_TOKEN='xapp-...'   # App-Level Token (connections:write)

# ── 운영 PC에서만 켠다 ──
# 코드를 읽기 전에 등록 프로젝트를 remote main 최신으로 맞춘다(reset --hard).
# 개발 PC에서는 절대 켜지 마라 — 내 로컬 작업 브랜치가 날아간다.
# export CODE_SYNC=1
# 모닝 브리핑을 게시할 채널. 이 값이 있으면 스케줄러가 켜진다.
# 개발 PC에서는 비워 둔다(브리핑 중복 게시 방지).
# export BRIEFING_CHANNEL='C...'
# export BRIEFING_NOTION_DB='...'

# ── 개발 PC 권장 설정 ──
# 개발 중엔 CODE_SYNC와 BRIEFING_CHANNEL을 둘 다 비워 둔다(위를 주석 처리한 채로).
# 그러면 내 로컬 코드를 그대로 읽고, 브리핑 스케줄러도 뜨지 않는다.
