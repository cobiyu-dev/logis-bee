{
  "name": "logisbi-slack-test",
  "version": "0.1.0",
  "description": "Slack 이벤트 수신 테스트 (Socket Mode)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "tsx src/app.ts",
    "grafana": "tsx src/grafana/cli.ts",
    "briefing": "tsx src/briefing-run.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/grafana/*.test.ts"
  },
  "dependencies": {
    "@slack/bolt": "^4",
    "node-cron": "^4.6.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4",
    "typescript": "^6.0.3"
  }
}
